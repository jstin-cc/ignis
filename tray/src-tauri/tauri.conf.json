{
  "productName": "Ignis",
  "version": "2.0.0",
  "identifier": "cc.jstin.ignis",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build && cargo build --release --bin ignis-api --manifest-path ../Cargo.toml && copy ..\\target\\release\\ignis-api.exe src-tauri\\binaries\\ignis-api-x86_64-pc-windows-msvc.exe",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Ignis",
        "width": 360,
        "height": 520,
        "minWidth": 360,
        "minHeight": 280,
        "maxWidth": 360,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "resizable": true,
        "url": "/"
      }
    ],
    "trayIcon": {
      "id": "ignis-tray",
      "iconPath": "icons/icon.ico",
      "iconAsTemplate": false,
      "menuOnLeftClick": false
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXkKUlVRa1FBQUE=",
      "endpoints": [
        "https://github.com/jstin-cc/ignis/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "externalBin": [
      "binaries/ignis-api"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
